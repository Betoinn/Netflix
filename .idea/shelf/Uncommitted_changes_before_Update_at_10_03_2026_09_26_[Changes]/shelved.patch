diff --git a/app/src/main/java/fr/isen/nicotom/netflix/FilmsScreen.kt b/app/src/main/java/fr/isen/nicotom/netflix/FilmsScreen.kt
new file mode 100644
--- /dev/null	(date 1773130411938)
